<!-- Modal -->
<div id="infoModal" class="modal fade" role="dialog">
  <div class="modal-dialog">
    <!-- Modal content-->
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">
            <span class="glyphicon glyphicon-remove-circle"></span>
        </button>
        <h3 class="modal-title">Riabilitazione cognitiva</h3>
      </div>
        <div class="modal-body">
            <h4>Qui puoi:</h4>
            <h4>1. Inserire nuovi <!--pazienti-->partecipanti e i loro profili anagrafici, clinici e neuropsicologici (completa per primo il profilo anagrafico, quindi quello clinico e infine quello neuropsicologico);</h4>
            <h4>2. Modificare o cancellare pazienti e i loro profili;</h4>
            <h4>3. Inserire i pazienti nel gruppo che preferisci;</h4>
            <h4>4. Scaricare i dati dei pazienti e i loro profili, che ti verranno inviati tramite email.</h4>
            <hr>
            <h3 style='color: red'><b>Questo sistema &egrave; destinato esclusivamente ad indagine clinica</b></h3>
        </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-success" data-dismiss="modal">Ok</button>
      </div>        
    </div>
  </div>
</div>